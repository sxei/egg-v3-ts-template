{
  "name": "egg-v3-ts-template",
  "version": "1.0.0",
  "description": "Egg.js v3 typescript template",
  "private": false,
  "egg": {
    "typescript": true
  },
  "scripts": {
    "dev": "egg-bin dev --dts --port 8080",
    "build": "ets && npm run tsc",
    "start": "egg-scripts start --port 8080 --workers 1",
    "stop": "egg-scripts stop",
    "debug": "egg-bin debug",
    "test-local": "egg-bin test",
    "test": "npm run lint -- --fix && npm run test-local",
    "cov": "egg-bin cov",
    "tsc": "tsc -p tsconfig.json",
    "ci": "npm run lint && npm run cov && npm run tsc",
    "lint": "eslint .",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "egg": "^3.11.0",
    "egg-decorator-router": "^1.0.7",
    "egg-scripts": "^2.17.0",
    "egg-sequelize": "^6.0.0",
    "egg-view-ejs": "^3.0.0",
    "egg-view-nunjucks": "^2.3.0",
    "moment": "^2.22.0",
    "mysql2": "^3.15.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eggjs/tsconfig": "^1.1.0",
    "@types/cheerio": "^0.22.1",
    "@types/mocha": "^10.0.1",
    "cheerio": "^1.0.0-rc.2",
    "egg-bin": "^5.9.0",
    "egg-mock": "^5.5.0",
    "eslint": "^8.31.0",
    "eslint-config-egg": "^12.1.0",
    "typescript": "^4.9.5"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  }
}
